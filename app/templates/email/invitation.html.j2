{% extends "_base.html.j2" %}
{% block title %}You're invited to view {{ project_name }}{% endblock %}
{% block content %}
<p class="greeting">Hello, {{ full_name }}!</p>
<p>You have been invited by <strong style="color: #e2e8f0;">{{ company_name }}</strong> to track the progress of your property in <strong style="color: #e2e8f0;">{{ project_name }}</strong>.</p>
<p>With BuildTrack, you can:</p>
<ul style="color: #94a3b8; padding-left: 20px; margin-bottom: 16px; line-height: 1.9;">
  <li>View real-time site photos with verified GPS locations</li>
  <li>Track construction milestones</li>
  <li>Receive instant notifications on updates</li>
</ul>
<div style="text-align: center;">
  <a href="https://buildtrack.co.ke/accept-invitation/{{ invitation_token }}" class="btn">Accept Invitation</a>
</div>
<hr class="divider">
<p style="font-size: 13px; color: #475569;">This invitation expires in <strong>{{ expires_days }} days</strong>. If you did not expect this email, you can safely ignore it.</p>
{% endblock %}
