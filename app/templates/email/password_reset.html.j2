{% extends "_base.html.j2" %}
{% block title %}Reset your BuildTrack password{% endblock %}
{% block content %}
<p class="greeting">Hello, {{ full_name }}!</p>
<p>We received a request to reset the password for your BuildTrack account. Click the button below to create a new password:</p>
<div style="text-align: center;">
  <a href="https://buildtrack.co.ke/reset-password?token={{ reset_token }}" class="btn">Reset Password</a>
</div>
<hr class="divider">
<p style="font-size: 13px; color: #475569;">This link expires in <strong>{{ expires_minutes }} minutes</strong>. If you didn't request a password reset, you can safely ignore this email — your password will remain unchanged.</p>
{% endblock %}
