{% extends "_base.html.j2" %}

{% block content %}
<p>Dear {{ first_name }},</p>
<p>{{ developer_company_name }} has updated the target date for a construction milestone on {{ project_name }}.</p>
<p>
  <strong>Milestone:</strong> {{ milestone_name }}<br>
  <strong>Previous date:</strong> {{ old_date }}<br>
  <strong>Revised date:</strong> {{ new_date }}
</p>
{% if reason %}
<p>{{ reason }}</p>
{% endif %}
<p>Your project page has been updated to reflect this change. All previous and future updates remain archived at:</p>
<p><a href="{{ project_page_url }}">{{ project_page_url }}</a></p>
<p>If you have questions about this revision, contact the {{ developer_company_name }} sales team directly through your project page.</p>
<p>The BuildTrack Team<br>buildtrack.co.ke</p>
{% endblock %}
