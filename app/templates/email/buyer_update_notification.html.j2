{% extends "_base.html.j2" %}
{% block title %}Construction Update — {{ project_name }} — {{ update_title }}{% endblock %}

{% block content %}
<div class="greeting">Dear {{ first_name }},</div>

<p><strong>{{ developer_name }}</strong> has posted a new verified construction update for <strong>{{ project_name }}</strong>.</p>

<div class="datacard">
    <p style="margin-bottom: 8px;"><strong>Update:</strong> {{ update_title }}</p>
    <p style="margin-bottom: 8px;"><strong>Category:</strong> <span class="badge">{{ update_category }}</span></p>
    <p style="margin-bottom: 8px;"><strong>Date:</strong> {{ update_date }}</p>
    <p style="margin-bottom: 8px;"><strong>Progress:</strong> {{ progress_percentage }}% overall</p>
    <p style="margin-bottom: 0;"><strong>Milestone:</strong> {{ milestone_name }} ({{ milestone_number }} of 5)</p>
</div>

<p style="margin-top: 24px; font-style: italic;">"{{ update_description }}"</p>

<p>This update includes <strong>{{ photo_count }} location-verified photographs</strong> taken on site.</p>

<p>View the full update and all previous records on your project page:</p>

<div style="text-align: center;">
    <a href="{{ project_url }}" class="btn">View Project Page</a>
</div>

<hr class="divider">

<div style="background-color: #134e4a; border: 1px solid #0F766E; border-radius: 8px; padding: 16px; margin-top: 24px;">
    <p style="margin-bottom: 0; font-size: 13px; color: #ccfbf1;">
        <strong>Location verification:</strong> All photos submitted through BuildTrack are locked to the registered site coordinates at the moment of capture. This update was submitted from <code>{{ gps_coordinates }}</code> on {{ capture_date }} at {{ capture_time }}.
    </p>
</div>

<p style="margin-top: 24px;">The BuildTrack Team<br>
<a href="https://buildtrack.co.ke" style="color: #14B8A6; text-decoration: none;">buildtrack.co.ke</a> | <a href="mailto:support@buildtrack.co.ke" style="color: #14B8A6; text-decoration: none;">support@buildtrack.co.ke</a></p>

<p style="font-size: 12px; color: #475569; margin-top: 24px;">
    You are receiving this email because you are a registered buyer on {{ project_name }}. To update your notification preferences, visit your portal settings.
</p>
{% endblock %}
