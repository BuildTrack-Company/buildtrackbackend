{% extends "_base.html.j2" %}

{% block content %}
<p>Dear {{ first_name }},</p>
<p>{{ developer_company_name }} has posted a new verified construction update for {{ project_name }}.</p>
<p>
  <strong>Update:</strong> {{ update_title }}<br>
  <strong>Category:</strong> {{ update_category }}<br>
  <strong>Date:</strong> {{ update_date }}<br>
  <strong>Progress:</strong> {{ progress_percentage }} % overall<br>
  <strong>Milestone:</strong> {{ milestone_name }} ({{ milestone_number }} of 5)
</p>
<p>{{ update_description }}</p>
<p>This update includes {{ photo_count }} location-verified photographs taken on site.</p>
<p>View the full update and all previous records on your project page:</p>
<p><a href="{{ project_page_url }}">{{ project_page_url }}</a></p>
<hr>
<p style="font-size: 12px; color: #555;">
  <strong>Location verification:</strong> All photos submitted through BuildTrack are locked to the registered site coordinates at the moment of capture. This update was submitted from {{ gps_coordinates }} on {{ update_date }} at {{ update_time }}.
</p>
<hr>
<p>The BuildTrack Team<br>buildtrack.co.ke | support@buildtrack.co.ke</p>
<p style="font-size: 11px; color: #888;">
  You are receiving this email because you are a registered buyer on {{ project_name }}. To update your notification preferences, visit your portal settings.
</p>
{% endblock %}
